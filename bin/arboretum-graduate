#!/usr/bin/env bash
# arboretum-graduate — sync arboretum-dev to arboretum public repo
#
# Usage:
#   arboretum-graduate <path-to-arboretum-public>
#
# Reads .graduateignore for exclusion patterns, then rsyncs arboretum-dev
# working tree to the target. Does NOT commit or push — you review
# the diff in the target repo and commit manually.

set -euo pipefail

# ── Resolve arboretum-dev repo location ──────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEV_ROOT="$(realpath "$SCRIPT_DIR/..")"

if [ ! -f "$DEV_ROOT/.graduateignore" ]; then
  echo "Error: Cannot find .graduateignore at $DEV_ROOT"
  echo "Are you running this from the arboretum-dev repo?"
  exit 1
fi

# ── Validate arguments ───────────────────────────────────────────

if [ $# -lt 1 ]; then
  echo "Usage: arboretum-graduate <path-to-arboretum-public>"
  echo ""
  echo "Syncs the current arboretum-dev state to the arboretum public repo,"
  echo "excluding paths listed in .graduateignore."
  exit 1
fi

TARGET="$(realpath "$1")"

if [ ! -d "$TARGET/.git" ]; then
  echo "Error: $TARGET does not appear to be a git repository."
  exit 1
fi

# ── Check we're on main ──────────────────────────────────────────

CURRENT_BRANCH="$(git -C "$DEV_ROOT" rev-parse --abbrev-ref HEAD)"
if [ "$CURRENT_BRANCH" != "main" ]; then
  echo "Error: arboretum-dev is on branch '$CURRENT_BRANCH', not 'main'."
  echo "Switch to main before graduating."
  exit 1
fi

# ── Check for uncommitted changes ────────────────────────────────

if ! git -C "$DEV_ROOT" diff --quiet || ! git -C "$DEV_ROOT" diff --cached --quiet; then
  echo "Error: arboretum-dev has uncommitted changes."
  echo "Commit or stash them before graduating."
  exit 1
fi

# ── Build rsync exclude list from .graduateignore ────────────────

EXCLUDE_ARGS=()
while IFS= read -r line; do
  # Skip blank lines and comments
  [[ -z "$line" || "$line" == \#* ]] && continue
  EXCLUDE_ARGS+=(--exclude "$line")
done < "$DEV_ROOT/.graduateignore"

# Always exclude git metadata and GitHub workflows
EXCLUDE_ARGS+=(--exclude ".git")
EXCLUDE_ARGS+=(--exclude ".github")
EXCLUDE_ARGS+=(--exclude "CLAUDE.md")
EXCLUDE_ARGS+=(--exclude "CLAUDE.public.md")
EXCLUDE_ARGS+=(--exclude "README.public.md")
EXCLUDE_ARGS+=(--exclude ".claude/projects/")

# ── Sync ─────────────────────────────────────────────────────────

echo "Graduating arboretum-dev → arboretum"
echo "  Source: $DEV_ROOT"
echo "  Target: $TARGET"
echo ""

# Dry run first to show what will change
echo "Changes to apply:"
echo ""
rsync -av --delete --dry-run "${EXCLUDE_ARGS[@]}" "$DEV_ROOT/" "$TARGET/" \
  | grep -v "^$" | grep -v "^sending" | grep -v "^sent " | grep -v "^total " \
  | grep -v "^\./$" || true

echo ""
read -p "Apply these changes? [y/N] " confirm
if [[ "$confirm" != [yY] ]]; then
  echo "Aborted."
  exit 0
fi

rsync -av --delete "${EXCLUDE_ARGS[@]}" "$DEV_ROOT/" "$TARGET/"

# Replace CLAUDE.md and README.md with public versions
cp "$DEV_ROOT/CLAUDE.public.md" "$TARGET/CLAUDE.md"
cp "$DEV_ROOT/README.public.md" "$TARGET/README.md"

echo ""
echo "Done. Changes applied to $TARGET."
echo ""
echo "Next steps:"
echo "  cd $TARGET"
echo "  git diff              # review changes"
echo "  git add -A && git commit"
echo "  git push"
