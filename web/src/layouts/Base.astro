---
// owner: digest-archive
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — PubMed Monitor</title>
    <style>
      :root {
        --max-width: 48rem;
        --color-bg: #fafafa;
        --color-text: #1a1a1a;
        --color-muted: #666;
        --color-border: #e5e5e5;
        --color-primary: #2563eb;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
      }
      nav {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 2rem;
        display: flex;
        gap: 1.5rem;
        align-items: center;
        max-width: var(--max-width);
        margin: 0 auto;
      }
      nav a { color: var(--color-primary); text-decoration: none; }
      nav a:hover { text-decoration: underline; }
      nav .brand { font-weight: 600; color: var(--color-text); }
      main {
        max-width: var(--max-width);
        margin: 2rem auto;
        padding: 0 2rem;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="brand">PubMed Monitor</a>
      <a href="/archive">Archive</a>
      <a href="/preferences" id="nav-prefs" style="display:none;">Preferences</a>
      <a href="/login" id="nav-login">Login</a>
      <a href="#" id="nav-logout" style="display:none;">Sign out</a>
    </nav>
    <script>
      import { supabase } from "../lib/supabase";

      async function updateNav() {
        const { data: { session } } = await supabase.auth.getSession();
        const loginLink = document.getElementById("nav-login")!;
        const logoutLink = document.getElementById("nav-logout")!;
        const prefsLink = document.getElementById("nav-prefs")!;

        if (session) {
          loginLink.style.display = "none";
          logoutLink.style.display = "";
          prefsLink.style.display = "";
        } else {
          loginLink.style.display = "";
          logoutLink.style.display = "none";
          prefsLink.style.display = "none";
        }
      }

      document.getElementById("nav-logout")!.addEventListener("click", async (e) => {
        e.preventDefault();
        await supabase.auth.signOut();
        window.location.href = "/";
      });

      // Listen for auth changes (e.g. callback page setting session)
      supabase.auth.onAuthStateChange(() => updateNav());
      updateNav();
    </script>
    <main>
      <slot />
    </main>
  </body>
</html>
