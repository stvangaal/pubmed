---
// owner: digest-archive
import Base from "../layouts/Base.astro";
---

<Base title="Preferences">
  <h1>Your Preferences</h1>
  <p style="margin-top: 0.5rem; color: var(--color-muted);">
    Choose which domains you'd like to receive digests for.
  </p>
  <div id="prefs-root" style="margin-top: 1.5rem;">
    <p style="color: var(--color-muted);">Loading...</p>
  </div>

  <script>
    import { supabase } from "../lib/supabase";

    const root = document.getElementById("prefs-root")!;

    // Available domains (matches config/domains/)
    const DOMAINS = ["stroke", "neurology"];

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      root.innerHTML = '<p>Please <a href="/login">sign in</a> to manage preferences.</p>';
    } else {
      // Fetch current subscriptions
      const { data: subs } = await supabase
        .from("subscriptions")
        .select("domain, active")
        .eq("user_id", session.user.id);

      const activeDomains = new Set(
        (subs || []).filter((s: any) => s.active).map((s: any) => s.domain)
      );

      root.innerHTML = "";
      for (const domain of DOMAINS) {
        const label = document.createElement("label");
        label.style.cssText = "display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;cursor:pointer;";

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.checked = activeDomains.has(domain);
        checkbox.addEventListener("change", async () => {
          if (checkbox.checked) {
            await supabase.from("subscriptions").upsert(
              { user_id: session.user.id, domain, active: true },
              { onConflict: "user_id,domain" }
            );
          } else {
            await supabase
              .from("subscriptions")
              .update({ active: false })
              .eq("user_id", session.user.id)
              .eq("domain", domain);
          }
        });

        const span = document.createElement("span");
        span.textContent = domain.charAt(0).toUpperCase() + domain.slice(1);
        span.style.fontSize = "1.1rem";

        label.appendChild(checkbox);
        label.appendChild(span);
        root.appendChild(label);
      }

      // Sign out link
      const signOut = document.createElement("a");
      signOut.href = "#";
      signOut.textContent = "Sign out";
      signOut.style.cssText = "display:block;margin-top:2rem;color:#666;";
      signOut.addEventListener("click", async (e) => {
        e.preventDefault();
        await supabase.auth.signOut();
        window.location.href = "/login";
      });
      root.appendChild(signOut);
    }
  </script>
</Base>
