---
// owner: digest-archive
import Base from "../../layouts/Base.astro";
---

<Base title="Archive">
  <h1>Digest Archive</h1>
  <p style="margin-top: 0.5rem; color: var(--color-muted);">
    Browse past weekly digests.
  </p>

  <div style="margin-top: 1rem;">
    <label for="domain-filter" style="font-weight: 500;">Domain: </label>
    <select id="domain-filter" style="padding: 0.25rem 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
      <option value="">All</option>
      <option value="stroke">Stroke</option>
      <option value="neurology">Neurology</option>
    </select>
  </div>

  <div id="digest-list" style="margin-top: 1.5rem;">
    <p style="color: var(--color-muted);">Loading...</p>
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    const listEl = document.getElementById("digest-list")!;
    const filterEl = document.getElementById("domain-filter") as HTMLSelectElement;

    async function loadDigests(domain?: string) {
      let query = supabase
        .from("digests")
        .select("id, domain, run_date, article_count, blog_url")
        .order("run_date", { ascending: false })
        .limit(50);

      if (domain) {
        query = query.eq("domain", domain);
      }

      const { data, error } = await query;
      if (error) {
        listEl.innerHTML = `<p style="color:red;">Error: ${error.message}</p>`;
        return;
      }

      if (!data || data.length === 0) {
        listEl.innerHTML = '<p style="color:var(--color-muted);">No digests found.</p>';
        return;
      }

      listEl.innerHTML = data
        .map(
          (d: any) => `
          <article style="border-bottom:1px solid var(--color-border);padding:1rem 0;">
            <h3 style="margin:0;">
              <a href="/archive/${d.id}" style="color:var(--color-primary);text-decoration:none;">
                ${d.domain.charAt(0).toUpperCase() + d.domain.slice(1)} — ${d.run_date}
              </a>
            </h3>
            <p style="color:var(--color-muted);margin-top:0.25rem;">
              ${d.article_count} article${d.article_count !== 1 ? "s" : ""}
              ${d.blog_url ? `· <a href="${d.blog_url}" style="color:var(--color-primary);">Blog</a>` : ""}
            </p>
          </article>
        `
        )
        .join("");
    }

    filterEl.addEventListener("change", () => loadDigests(filterEl.value || undefined));
    loadDigests();
  </script>
</Base>
