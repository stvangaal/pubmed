.superpowers/

# Pipeline output (regenerated each run)
output/

# Runtime state (per-installation, not config)
data/seen-pmids.json
data/domains/*/wp-pages-state.yaml

# Evaluation cache (fetched PubMed records, not committed)
data/eval/.cache/

# Evaluation run history (local tracking)
data/eval/triage-history.jsonl

# Workflow progress (per-session, cross-session resumption)
.claude/progress/

# E2E test state (created/deleted test post IDs)
data/e2e-test/

# Spike results (development only)
spikes/*/spike_results*.json
/tmp/
